# Copy this file to config/local.env and set a source directory.
# Start with a disposable fixture, never with the live vault.
BACKUP_SOURCE=""

# Name of the pre-configured rclone MEGA remote, without the trailing colon.
RCLONE_REMOTE_NAME="mega"
RCLONE_REMOTE_PATH="ObsidianVaultBackup"

# This name scopes the Kopia repository password in macOS Keychain.
KEYCHAIN_SERVICE="com.example.obsidian-vault-backup.kopia"
KEYCHAIN_ACCOUNT="repository-password"

